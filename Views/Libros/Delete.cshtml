@model T3_HUACCHA_ANGEL.Models.Libro
<div class="alert alert-danger my-4 shadow-sm" role="alert">
    <h4 class="alert-heading">¿Estás seguro de eliminar este registro?</h4>
    <p>Esta acción removerá el libro permanentemente.</p>
</div>
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">Título:</dt>
            <dd class="col-sm-9">@Model.Titulo</dd>
            <dt class="col-sm-3 fw-bold">Autor:</dt>
            <dd class="col-sm-9">@Model.Autor</dd>
            <dt class="col-sm-3 fw-bold">Editorial:</dt>
            <dd class="col-sm-9">@Model.Editorial</dd>
        </dl>
    </div>
</div>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirmar Eliminación</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>