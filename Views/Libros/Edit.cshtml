@model T3_HUACCHA_ANGEL.Models.Libro
<div class="card shadow-sm my-4">
    <div class="card-header bg-warning text-dark"><h4>Modificar Libro</h4></div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Titulo" class="form-label fw-bold"></label>
                    <input asp-for="Titulo" class="form-control" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Autor" class="form-label fw-bold"></label>
                    <input asp-for="Autor" class="form-control" />
                    <span asp-validation-for="Autor" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Tema" class="form-label fw-bold"></label>
                    <input asp-for="Tema" class="form-control" />
                    <span asp-validation-for="Tema" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Editorial" class="form-label fw-bold"></label>
                    <input asp-for="Editorial" class="form-control" />
                    <span asp-validation-for="Editorial" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="AnioPublicacion" class="form-label fw-bold"></label>
                    <input asp-for="AnioPublicacion" type="number" class="form-control" />
                    <span asp-validation-for="AnioPublicacion" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Paginas" class="form-label fw-bold"></label>
                    <input asp-for="Paginas" type="number" class="form-control" />
                    <span asp-validation-for="Paginas" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="Copias" class="form-label fw-bold"></label>
                    <input asp-for="Copias" type="number" class="form-control" />
                    <span asp-validation-for="Copias" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Categoria" class="form-label fw-bold"></label>
                    <input asp-for="Categoria" class="form-control" />
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Material" class="form-label fw-bold"></label>
                    <input asp-for="Material" class="form-control" />
                    <span asp-validation-for="Material" class="text-danger"></span>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Actualizar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}